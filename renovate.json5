{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
  ],
  minimumReleaseAge: "7 days",
  lockFileMaintenance: {
    enabled: true,
  },
  labels: [
    "dependencies",
  ],
  packageRules: [
    {
      matchCategories: [
        "ci",
      ],
      addLabels: [
        "ci",
      ]
    },
    {
      matchManagers: [
        "pep621",
      ],
      matchDepTypes: [
        "dependency-groups",
      ],
      addLabels: [
        "dev dependencies",
      ],
      automerge: true,
    },
  ],
}
